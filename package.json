{
  "name": "v-maplibre-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Vinayak Kulkarni",
    "email": "inbox.vinayak@gmail.com",
    "url": "https://vinayakkulkarni.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/geoql/v-maplibre.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @geoql/v-maplibre run build && pnpm --filter @geoql/mapcn-vue run build && pnpm --filter @geoql/v-maplibre-docs run build && pnpm --filter @geoql/mapcn-vue-app run build",
    "build:docs": "pnpm --filter @geoql/v-maplibre-docs run build",
    "build:mapcn": "pnpm --filter @geoql/mapcn-vue-app run build",
    "dev:docs": "pnpm --filter @geoql/v-maplibre-docs run dev",
    "dev:mapcn": "pnpm --filter @geoql/mapcn-vue-app run dev",
    "dev:lib": "pnpm --filter @geoql/v-maplibre run dev",
    "lint": "pnpm -r run lint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "pnpm --filter @geoql/v-maplibre run test",
    "test:coverage": "pnpm --filter @geoql/v-maplibre run test:coverage",
    "prepare": "husky || true",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/.nuxt apps/*/.output",
    "update:deps": "pnpm dlx taze -I -r"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  }
}
