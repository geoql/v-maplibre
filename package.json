  "type": "module",
  "scripts": {
    "build": "bun run --cwd packages/v-maplibre build && bun run --cwd packages/mapcn-vue build && bun run --cwd apps/docs build && bun run --cwd apps/mapcn-vue build",
    "build:docs": "cd apps/docs && bun run build",
    "build:mapcn": "bun run --cwd apps/mapcn-vue build",
    "setup:docs": "cd apps/docs && bun install",
    "dev:docs": "cd apps/docs && bun run dev",
    "dev:mapcn": "bun run --cwd apps/mapcn-vue dev",
    "dev:lib": "bun run --cwd packages/v-maplibre dev",
    "lint": "bun run --filter '!@geoql/v-maplibre-docs' lint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "bun run --cwd packages/v-maplibre test",
    "test:coverage": "bun run --cwd packages/v-maplibre test:coverage",
    "prepare": "husky || true",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules packages/*/dist apps/*/.nuxt apps/*/.output"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.11"
}
